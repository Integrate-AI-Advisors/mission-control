# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Encryption (same key must be set on VPS platform)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Platform API (for integration health checks)
PLATFORM_API_URL=https://api.integrate-ai.uk

# Legacy (still used for IntegrateAI direct-VPS fallback)
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_SKILLS_ROOT=/root/openclaw
USAGE_REPORT_SCRIPT=/root/.openclaw/scripts/usage-report.sh
